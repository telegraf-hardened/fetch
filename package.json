{
  "name": "@telegraf-hardened/fetch",
  "version": "1.0.3",
  "description": "Native fetch wrapper for Node.js 18+ with built-in SOCKS5 and HTTP/HTTPS proxy support via undici dispatchers.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --sourcemap --out-extension .cjs=cjs --out-extension .esm=mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "keywords": [
    "fetch",
    "undici",
    "proxy",
    "socks5",
    "socks",
    "hardened",
    "telegraf",
    "http-proxy"
  ],
  "author": "siakinnik",
  "license": "MIT",
  "dependencies": {
    "socks": "^2.8.4",
    "undici": "^7.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
